{
  "name": "@hermes/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "exec tsx watch src/index.ts",
    "start:prod": "node --experimental-specifier-resolution=node -r tsx src/index.ts",
    "build": "tsc --outDir dist --esModuleInterop --module nodenext --moduleResolution nodenext --target es2022 src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hermes/backtest": "^0.1.0",
    "@hermes/broker-router": "^0.1.0",
    "@hermes/contracts": "file:../../packages/contracts",
    "@hermes/infra": "file:../../packages/infra",
    "@hermes/logger": "file:../../packages/logger",
    "@hermes/market-data": "^0.1.0",
    "@hermes/review-loop": "^0.1.0",
    "@hermes/risk-engine": "^0.1.0",
    "@hermes/strategy-lab": "^0.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@types/pg": "^8.20.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "tsx": "^4.21.0"
  }
}
