{
  "name": "@hermes/daily-diary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "exec tsx watch src/index.ts",
    "start": "node --experimental-specifier-resolution=node -r tsx src/index.ts",
    "build": "tsc --outDir dist --esModuleInterop --module nodenext --moduleResolution nodenext --target es2022 src/index.ts"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
